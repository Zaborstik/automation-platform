# Address of the platform-api gateway running on the SERVER.
# Replace with your actual server URL before `docker compose up`.
PLATFORM_API_URL=https://your-server.example.com

# Default base URL the agent should open in the browser when no plan
# provides an explicit URL. Usually the same as PLATFORM_API_URL or the
# product you are automating.
PLATFORM_AGENT_BASE_URL=https://your-server.example.com

# Run the browser headless inside the container (recommended).
PLATFORM_AGENT_HEADLESS=true

# Port on the host where chat-overlay / CLI will reach the executor.
PLATFORM_EXECUTOR_PORT=7070

# Optional log verbosity (DEBUG/INFO/WARN).
LOG_LEVEL=INFO

# Optional image overrides — useful for pulling pre-built images instead
# of rebuilding locally.
# AGENT_IMAGE=ghcr.io/your-org/platform-agent:1.0.0
# EXECUTOR_IMAGE=ghcr.io/your-org/platform-executor:1.0.0
# PLAYWRIGHT_IMAGE=ghcr.io/your-org/platform-playwright:1.0.0
