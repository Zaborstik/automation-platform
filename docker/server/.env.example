# Postgres
POSTGRES_DB=platformdb
POSTGRES_USER=platform
POSTGRES_PASSWORD=change-me-in-prod

# Port exposed for the platform-api gateway (the only public-facing service).
# Knowledge and Postgres stay private inside the compose network.
PLATFORM_API_PORT=8080

# Optional log verbosity (DEBUG/INFO/WARN).
LOG_LEVEL=INFO

# Optional image overrides — useful when pulling pre-built images from a
# registry instead of rebuilding locally.
# API_IMAGE=ghcr.io/your-org/platform-api:1.0.0
# KNOWLEDGE_IMAGE=ghcr.io/your-org/platform-knowledge:1.0.0
