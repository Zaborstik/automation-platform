# Копируйте в .env.deploy (файл в .gitignore — не коммитьте пароли).
#
# Автодеплой на удалённый сервер: синхронизирует репозиторий по SSH и
# запускает scripts/deploy-server.sh на хосте.
#
# deps на вашей машине: rsync, ssh; для пароля к SSH нужен sshpass:
#   macOS: brew install sshpass hudochenkov/sshpass/sshpass
#   Linux: sudo apt install sshpass

# Обязательно: IP или DNS сервера
DEPLOY_REMOTE_HOST=203.0.113.10

# Пользователь SSH (часто ubuntu, debian, root)
DEPLOY_REMOTE_USER=ubuntu

# Пароль SSH (если пусто — используется ssh-agent / ключи из ~/.ssh)
DEPLOY_REMOTE_PASSWORD=

# Каталог на сервере (полный путь; не используйте ~/ — при source .env ~ подставит ВАШ локальный $HOME).
DEPLOY_REMOTE_DIR=/home/ubuntu/automation-platform

# Если задать — на сервере будет создан docker/server/.env с этим паролем БД.
# Если пусто — скопируется ваш локальный docker/server/.env (если есть),
# иначе на сервере подставится только .env.example (НЕ для продакшена).
DEPLOY_POSTGRES_PASSWORD=

# Доп. флаги для deploy-server.sh на сервере, например: --pull
# DEPLOY_SERVER_EXTRA_ARGS=--pull
